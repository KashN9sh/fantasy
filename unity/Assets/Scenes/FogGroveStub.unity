--- !u!114 &1299304085
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 1299304084}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: f5a6b7c8d9e0718293a5b6c7d8e9f0a1, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::TikhayaTropa.Interaction.HollowTreeInteractable
  prompt: "\u0417\u0430\u0433\u043B\u044F\u043D\u0443\u0442\u044C \u0432 \u0434\u0443\u043F\u043B\u043E"
  examineText: "\u0412 \u0436\u0435\u0441\u0442\u044F\u043D\u043E\u0439 \u043A\u043E\u0440\u043E\u0431\u043A\u0435
    \u2014 \u0437\u0430\u043F\u0438\u0441\u043A\u0430: \xAB\u0415\u0441\u043B\u0438
    \u0442\u044B \u0447\u0438\u0442\u0430\u0435\u0448\u044C \u044D\u0442\u043E \u2014
    \u0437\u043D\u0430\u0447\u0438\u0442, \u0442\u044B \u043D\u0435 \u0437\u0430\u0431\u043B\u0443\u0434\u0438\u043B\u0441\u044F.
    \u0422\u044B \u043F\u0440\u043E\u0441\u0442\u043E \u0435\u0449\u0451 \u043D\u0435
    \u043D\u0430\u0448\u0451\u043B \u0434\u043E\u0440\u043E\u0433\u0443. \u042D\u0442\u043E
    \u043D\u0435 \u043E\u0434\u043D\u043E \u0438 \u0442\u043E \u0436\u0435.\xBB\n\n\u0420\u044F\u0434\u043E\u043C
    \u2014 \u043F\u0443\u0447\u043E\u043A \u0441\u0443\u0445\u043E\u0439 \u043B\u0430\u0432\u0430\u043D\u0434\u044B."
  doneFlavor: "\u041A\u043E\u0440\u043E\u0431\u043A\u0430 \u043F\u0443\u0441\u0442\u0430,
    \u043D\u043E \u0437\u0430\u043F\u0430\u0445 \u043B\u0430\u0432\u0430\u043D\u0434\u044B
    \u0435\u0449\u0451 \u0434\u0435\u0440\u0436\u0438\u0442\u0441\u044F \u0432 \u0434\u0443\u043F\u043B\u0435."
