--- !u!114 &487296942
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 487296941}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: e2f3a4b5c6d7485960708192a3b4c5d6, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::TikhayaTropa.Interaction.LostSignpostInteractable
  calmZone: {fileID: 0}
  examineText: "\u0423\u043F\u0430\u0432\u0448\u0438\u0439 \u0441\u0442\u043E\u043B\u0431.
    \u0422\u0440\u0438 \u0441\u0442\u0440\u0435\u043B\u043A\u0438 \u0441\u043C\u043E\u0442\u0440\u044F\u0442
    \u0432 \u0440\u0430\u0437\u043D\u044B\u0435 \u0441\u0442\u043E\u0440\u043E\u043D\u044B
    \u2014 \u043D\u0438 \u043E\u0434\u043D\u043E\u0439 \u043D\u0430\u0434\u043F\u0438\u0441\u0438.
    \u041A\u0443\u0434\u0430 \u043D\u0438 \u0433\u043B\u044F\u043D\u044C, \u0432\u0441\u0451
    \u043E\u0434\u0438\u043D\u0430\u043A\u043E\u0432\u043E \u043D\u0435\u044F\u0441\u043D\u043E."
  hintStandStill: "\u0415\u0441\u043B\u0438 \u043F\u0440\u043E\u0441\u0442\u043E
    \u043F\u043E\u0441\u0442\u043E\u044F\u0442\u044C \u0440\u044F\u0434\u043E\u043C
    \u0438 \u043F\u043E\u0441\u043B\u0443\u0448\u0430\u0442\u044C \u0442\u0438\u0448\u0438\u043D\u0443
    \u2014 \u043C\u043E\u0436\u0435\u0442, \u0442\u0443\u043C\u0430\u043D \u043E\u0442\u0441\u0442\u0443\u043F\u0438\u0442
    \u043D\u0430 \u0448\u0430\u0433."
  wonderText: "\u0422\u044B \u0437\u0430\u043C\u0438\u0440\u0430\u0435\u0448\u044C.
    \u0412 \u0441\u0435\u0440\u043E\u0439 \u0434\u044B\u043C\u043A\u0435 \u0432\u0441\u043F\u044B\u0445\u0438\u0432\u0430\u044E\u0442
    \u043C\u0435\u043B\u043A\u0438\u0435 \u0442\u0451\u043F\u043B\u044B\u0435 \u0442\u043E\u0447\u043A\u0438
    \u2014 \u043A\u0430\u043A \u0441\u0432\u0435\u0442\u043B\u044F\u0447\u043A\u0438.
    \u0422\u0443\u043C\u0430\u043D \u043D\u0430\u0434 \u0442\u0440\u043E\u043F\u043E\u0439
    \u0440\u0435\u0434\u0435\u0435\u0442 \u043D\u0430 \u043C\u0433\u043D\u043E\u0432\u0435\u043D\u0438\u0435,
    \u0438 \u0441\u043D\u043E\u0432\u0430 \u0441\u043C\u044B\u043A\u0430\u0435\u0442\u0441\u044F.\n\n\u0422\u044B
    \u0432\u0441\u0451 \u0435\u0449\u0451 \u043D\u0435 \u0437\u043D\u0430\u0435\u0448\u044C,
    \u043A\u0443\u0434\u0430 \u0438\u0434\u0442\u0438. \u041D\u043E \u0441\u043B\u0435\u0434\u0443\u044E\u0449\u0438\u0439
    \u0448\u0430\u0433 \u0432\u0438\u0434\u0435\u043D."
  doneFlavor: "\u0421\u0442\u0440\u0435\u043B\u043A\u0438 \u043F\u043E-\u043F\u0440\u0435\u0436\u043D\u0435\u043C\u0443
    \u043C\u043E\u043B\u0447\u0430\u0442. \u041D\u043E \u0442\u0440\u043E\u043F\u0430
    \u043F\u043E\u0434 \u043D\u043E\u0433\u0430\u043C\u0438 \u0447\u0443\u0442\u044C
    \u043E\u0442\u0447\u0451\u0442\u043B\u0438\u0432\u0435\u0435."
