  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::TikhayaTropa.Blobber.BlobberSimpleInteractable
  promptText: "\u041E\u0441\u043C\u043E\u0442\u0440\u0435\u0442\u044C \u043A\u0430\u043B\u0438\u0442\u043A\u0443"
  message: "\u041D\u0430 \u043F\u043E\u0442\u0435\u043C\u043D\u0435\u0432\u0448\u0435\u043C
    \u0434\u0435\u0440\u0435\u0432\u0435 \u0432\u044B\u0440\u0435\u0437\u0430\u043D\u043E:
    \xAB\u041A\u0442\u043E \u0438\u0434\u0451\u0442 \u2014 \u0442\u043E\u0442 \u0443\u0436\u0435
    \u043D\u0430\u0447\u0430\u043B\xBB."
  setFlag: 
  requireFlag: 
  diaryId: blobber-gate
  diaryText: "\u041A\u0430\u043B\u0438\u0442\u043A\u0430 \u043E\u0441\u0442\u0430\u043B\u0430\u0441\u044C
    \u043F\u043E\u0437\u0430\u0434\u0438. \u0412\u043E\u0437\u0432\u0440\u0430\u0442\u0430
    \u043A \u043F\u0440\u0435\u0436\u043D\u0435\u043C\u0443 \u0443\u0436\u0435 \u043D\u0435\u0442."
  loadScene: 
  setChapterAct: 1
