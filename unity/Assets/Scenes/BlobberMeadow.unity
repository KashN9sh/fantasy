  promptText: "\u041F\u043E\u0433\u043E\u0432\u043E\u0440\u0438\u0442\u044C \u0441
    \u043E\u0442\u0448\u0435\u043B\u044C\u043D\u0438\u043A\u043E\u043C"
  message: "\u041E\u0442\u0448\u0435\u043B\u044C\u043D\u0438\u043A \u0441\u0438\u0434\u0438\u0442
    \u043D\u0430 \u0442\u0451\u043F\u043B\u043E\u043C \u043A\u0430\u043C\u043D\u0435:
    \xAB\u041D\u0435 \u0442\u043E\u0440\u043E\u043F\u0438\u0441\u044C. \u0421\u043B\u044B\u0448\u0438\u0448\u044C
    \u0441\u0435\u0431\u044F \u2014 \u0443\u0436\u0435 \u043F\u0443\u0442\u044C.\xBB"
  setFlag: 
  requireFlag: 
  diaryId: blobber-hermit
  diaryText: "\u042F \u0432\u0441\u0442\u0440\u0435\u0442\u0438\u043B \u043E\u0442\u0448\u0435\u043B\u044C\u043D\u0438\u043A\u0430.
