  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::TikhayaTropa.Blobber.BlobberSimpleInteractable
  promptText: "\u0417\u0430\u0433\u043B\u044F\u043D\u0443\u0442\u044C \u0432 \u043A\u043E\u043B\u043E\u0434\u0435\u0446"
  message: "\u0412 \u0433\u043B\u0443\u0431\u0438\u043D\u0435 \u043D\u0435 \u0432\u0438\u0434\u043D\u043E
    \u0432\u043E\u0434\u044B. \u041D\u043E \u0435\u0441\u043B\u0438 \u043F\u0440\u043E\u0448\u0435\u043F\u0442\u0430\u0442\u044C
    \u0442\u0440\u0435\u0432\u043E\u0433\u0443 \u2014 \u0432\u0435\u0442\u0435\u0440
    \u043E\u0442\u0432\u0435\u0447\u0430\u0435\u0442 \u0442\u0435\u043F\u043B\u043E\u043C
    \u0432 \u043B\u0430\u0434\u043E\u043D\u0438."
  setFlag: 
  requireFlag: 
  diaryId: blobber-well
  diaryText: "\u041A\u043E\u043B\u043E\u0434\u0435\u0446 \u043C\u043E\u043B\u0447\u0430\u043B,
    \u043D\u043E \u043F\u043E\u0441\u043B\u0435 \u043D\u0435\u0433\u043E \u0441\u0442\u0430\u043B\u043E
    \u0447\u0443\u0442\u044C \u0442\u0435\u043F\u043B\u0435\u0435 \u0432\u043D\u0443\u0442\u0440\u0438."
  loadScene: 
  setChapterAct: 1
