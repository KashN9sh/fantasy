  inscription: "\u041A\u0442\u043E \u0438\u0434\u0451\u0442 \u2014 \u0442\u043E\u0442
    \u0443\u0436\u0435 \u043D\u0430\u0447\u0430\u043B."
  diaryAfterPass: "\u042F \u043F\u0440\u043E\u0448\u0451\u043B \u0447\u0435\u0440\u0435\u0437
    \u043A\u0430\u043B\u0438\u0442\u043A\u0443. \u041D\u0430\u0437\u0430\u0434 \u043D\u0435\u043B\u044C\u0437\u044F.
    \u0412\u043F\u0435\u0440\u0435\u0434\u0438 \u2014 \u043D\u0435\u0438\u0437\u0432\u0435\u0441\u0442\u043D\u043E.
    \u041D\u043E \u044F \u0438\u0434\u0443."
