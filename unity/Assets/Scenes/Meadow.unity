--- !u!114 &1776124936
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 1776124935}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: c4f8a91e2d0b4e6a9c3d7e1f5a8b2c6d, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::TikhayaTropa.Interaction.BenchInscriptionsInteractable
  prompt: "\u0421\u043A\u0430\u043C\u0435\u0439\u043A\u0430 \u043F\u043E\u0434 \u0434\u0443\u0431\u043E\u043C"
  line1: "\u041D\u0430 \u0441\u043F\u0438\u043D\u043A\u0435 \u2014 \u0434\u0435\u0441\u044F\u0442\u043A\u0438
    \u043C\u0435\u043B\u043A\u0438\u0445 \u043D\u0430\u0434\u043F\u0438\u0441\u0435\u0439.
    \u0411\u043E\u043B\u044C\u0448\u0438\u043D\u0441\u0442\u0432\u043E \u0441\u0442\u0451\u0440\u043B\u043E\u0441\u044C
    \u043E\u0442 \u0441\u043E\u043B\u043D\u0446\u0430 \u0438 \u0434\u043E\u0436\u0434\u044F."
  line2: "\u041A\u043E\u0435-\u0433\u0434\u0435 \u0443\u0433\u0430\u0434\u044B\u0432\u0430\u044E\u0442\u0441\u044F
    \u043E\u0442\u0434\u0435\u043B\u044C\u043D\u044B\u0435 \u0441\u043B\u043E\u0432\u0430:
    \xAB\u2026\u0434\u0435\u0440\u0436\u0430\u043B\u043E\u0441\u044C\u2026\xBB, \xAB\u2026\u043B\u0435\u0433\u0447\u0435\u2026\xBB,
    \xAB\u2026\u0441\u043F\u0430\u0441\u0438\u0431\u043E\u2026\xBB \u2014 \u0447\u0443\u0436\u0438\u0435
    \u0441\u043B\u0435\u0434\u044B."
  line3: "\u041E\u0434\u043D\u0430 \u0441\u0442\u0440\u043E\u043A\u0430 \u043F\u043E\u0447\u0442\u0438
    \u0446\u0435\u043B\u0438\u043A\u043E\u043C \u0441\u044A\u0435\u0434\u0435\u043D\u0430
    \u043C\u0445\u043E\u043C. \u041E\u0441\u0442\u0430\u0451\u0442\u0441\u044F \u043E\u0449\u0443\u0449\u0435\u043D\u0438\u0435,
    \u0447\u0442\u043E \u0435\u0451 \u043F\u0438\u0441\u0430\u043B\u0438 \u0434\u0440\u043E\u0436\u0430\u0449\u0435\u0439
    \u0440\u0443\u043A\u043E\u0439."
  lineFinal: "\u0422\u044B \u043F\u0440\u0438\u0441\u0430\u0436\u0438\u0432\u0430\u0435\u0448\u044C\u0441\u044F
    \u0447\u0443\u0442\u044C \u0438\u043D\u0430\u0447\u0435 \u2014 \u0438 \u0432\u043D\u0435\u0437\u0430\u043F\u043D\u043E
    \u0447\u0438\u0442\u0430\u0435\u0448\u044C \u044F\u0441\u043D\u043E: \xAB\u042F
    \u0431\u044B\u043B \u0437\u0434\u0435\u0441\u044C. \u041C\u043D\u0435 \u0441\u0442\u0430\u043B\u043E
    \u043B\u0435\u0433\u0447\u0435.\xBB"
  doneFlavor: "\u0422\u044B \u0441\u043D\u043E\u0432\u0430 \u043F\u0440\u043E\u0432\u043E\u0434\u0438\u0448\u044C
    \u043F\u0430\u043B\u044C\u0446\u0430\u043C\u0438 \u043F\u043E \u0437\u043D\u0430\u043A\u043E\u043C\u044B\u043C
    \u0431\u043E\u0440\u043E\u0437\u0434\u0430\u043C \u0434\u0435\u0440\u0435\u0432\u0430.
    \u0422\u0435\u043F\u043B\u043E \u043E\u0441\u0442\u0430\u0451\u0442\u0441\u044F."
