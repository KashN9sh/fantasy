  m_Script: {fileID: 11500000, guid: 0e54866e519ed41358e8f7da29caacbb, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::TikhayaTropa.Directors.ControlsTutorialController
  tutorialRoot: {fileID: 883076567}
  bodyText: {fileID: 90929559}
  dismissButton: {fileID: 305731981}
  tutorialCopy: "\u0425\u043E\u0434\u044C\u0431\u0430 \u2014 A / D \u0438\u043B\u0438
    \u0441\u0442\u0440\u0435\u043B\u043A\u0438 \u0432\u043B\u0435\u0432\u043E-\u0432\u043F\u0440\u0430\u0432\u043E.\n\u0411\u0435\u0433
    \u2014 \u0437\u0430\u0436\u043C\u0438 Shift.\n\u041F\u0440\u044B\u0436\u043E\u043A
    \u2014 \u041F\u0440\u043E\u0431\u0435\u043B.\n\u0414\u043D\u0435\u0432\u043D\u0438\u043A
    \u2014 J.\n\u0412\u0437\u0430\u0438\u043C\u043E\u0434\u0435\u0439\u0441\u0442\u0432\u0438\u0435
    \u0441 \u043C\u0438\u0440\u043E\u043C \u2014 E.\n\n\u0420\u044F\u0434\u043E\u043C
    \u0441 \u043E\u0431\u044A\u0435\u043A\u0442\u0430\u043C\u0438 \u043F\u043E\u044F\u0432\u0438\u0442\u0441\u044F
    \u043A\u043E\u0440\u043E\u0442\u043A\u0430\u044F \u043F\u043E\u0434\u0441\u043A\u0430\u0437\u043A\u0430,
    \u0447\u0442\u043E \u043C\u043E\u0436\u043D\u043E \u0441\u0434\u0435\u043B\u0430\u0442\u044C."
--- !u!114 &580831256
