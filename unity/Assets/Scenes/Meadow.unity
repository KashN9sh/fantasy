  introLine: {fileID: 507955505}
  lineDuration: 4
  fadeDuration: 1.2
  secondLineHold: 2.8
  secondLine: "\u0421\u0435\u0440\u043E\u0441\u0442\u044C \u0437\u0430 \u0441\u043F\u0438\u043D\u043E\u0439
    \u0440\u0430\u0441\u0442\u0432\u043E\u0440\u044F\u0435\u0442\u0441\u044F. \u0412\u043F\u0435\u0440\u0435\u0434\u0438
    \u2014 \u0441\u0432\u0435\u0442, \u0442\u0440\u0430\u0432\u0430 \u0438 \u0434\u0435\u0440\u0435\u0432\u044F\u043D\u043D\u0430\u044F
    \u043A\u0430\u043B\u0438\u0442\u043A\u0430."
